# Copy to .env and replace placeholders.

# ─────────────────────────────────────────────────────────────
# 1. TAVILY (Web search + extract) — multi-key rotation
# ─────────────────────────────────────────────────────────────
# Provide one OR many keys. The pipeline rotates to the next key
# automatically when one returns 401/402/403/429 or a quota error.
# When ALL keys are exhausted the pipeline checkpoints state and
# exits cleanly — re-run after adding more keys to resume.

# Preferred form: comma-separated list
TAVILY_API_KEYS=tvly-dev-key1,tvly-dev-key2,tvly-dev-key3,tvly-dev-key4,tvly-dev-key5,tvly-dev-key6

# Or numbered (TAVILY_API_KEY_1 .. TAVILY_API_KEY_10)
# TAVILY_API_KEY_1=tvly-dev-key1
# TAVILY_API_KEY_2=tvly-dev-key2

# Or single-key fallback
# TAVILY_API_KEY=tvly-dev-key1

# ─────────────────────────────────────────────────────────────
# 2. POSTGRES (metadata)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ─────────────────────────────────────────────────────────────
# 3. BACKBLAZE B2 (raw documents)
# ─────────────────────────────────────────────────────────────
B2_BUCKET_NAME=Gnemexplorer
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_ACCESS_KEY_ID=change-me
B2_SECRET_ACCESS_KEY=change-me

# ─────────────────────────────────────────────────────────────
# 4. QDRANT (vector store — phase 2)
# ─────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=change-me
QDRANT_COLLECTION_NAME=georgia_ev_chunks
QDRANT_DENSE_VECTOR_NAME=dense
QDRANT_SPARSE_VECTOR_NAME=sparse
QDRANT_VECTOR_DIMENSIONS=768

# ─────────────────────────────────────────────────────────────
# 5. NEO4J (knowledge graph — phase 3)
# ─────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me

# ─────────────────────────────────────────────────────────────
# 6. OLLAMA (local LLM — phases 1/3/4)
# ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_CYPHER_MODEL=qwen2.5:7b
OLLAMA_LLM_FALLBACK=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────────────────────────
# 7. PROJECT
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
PROJECT_NAME=Georgia EV Supply Chain Intelligence
