# sreeja-arch — environment template.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Never commit secrets.

# ── Ollama (local LLM + embeddings) ────────────────────────────────────────
# Default is http://localhost:11434. Override only for remote Ollama.
OLLAMA_BASE_URL=
# Embedding model used both for query embedding and as the ragas embedder.
OLLAMA_EMBED_MODEL=

# ── Qdrant (vector store) ──────────────────────────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
# Code defaults to georgia_ev_chunks. Override only if you have re-ingested
# under a different collection name.
QDRANT_COLLECTION_NAME=
QDRANT_DENSE_VECTOR_NAME=
QDRANT_SPARSE_VECTOR_NAME=

# ── Tavily (web search, used only by mode rag_pretrained_web) ──────────────
TAVILY_API_KEY=

# ── Judge LLM for official RAGAS evaluation ────────────────────────────────
# Kimi 2.6 is OpenAI-compatible. JUDGE_BASE_URL is the API host (e.g.
# https://api.moonshot.ai/v1). JUDGE_MODEL is the deployed model id.
JUDGE_BASE_URL=
JUDGE_API_KEY=
JUDGE_MODEL=

# ── Reranker (mandatory for all RAG modes) ─────────────────────────────────
# Override only if you have a different cross-encoder available locally.
CROSS_ENCODER_RERANKER_MODEL=
